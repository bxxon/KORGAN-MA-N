          ],
          "dtype": "tensor(float)"
        }
      ],
      "outputs": [
        {
          "name": "output0",
          "shape": [
            1,
            84,
            8400
          ],
          "dtype": "tensor(float)"
        }
      ]
    }
  },
  "model": {
    "format": "ONNX",
    "producer": {
      "name": "pytorch",
      "version": "2.7.1"
    },
    "ir_version": 7,
    "opset_imports": [
      {
        "domain": "ai.onnx",
        "version": 12
      }
    ],
    "sha256": "59d4bd673073651a31b56d0f5a207b60a98867742fd389242781a8ccb90d31b9",
    "class_count": 80,
    "labels_source": "labels.txt"
  },
  "preprocessing": {
    "color_order": "RGB",
    "input_layout": "NCHW",
    "input_tensor_name": "images",
    "input_dtype": "float32",
    "input_size": [
      640,
      640
    ],
    "resize": {
      "mode": "direct",
      "keep_aspect_ratio": false
    },
    "normalization": {
      "scale": 0.00392156862745098,
      "formula": "pixel / 255.0"
