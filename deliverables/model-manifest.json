        {
          "name": "class_id",
          "type": "int32"
        },
        {
          "name": "label",
          "type": "string",
          "source": "labels.txt[class_id]"
        },
        {
          "name": "confidence",
          "type": "float32"
        },
        {
          "name": "bbox_xyxy",
          "type": "float32[4]",
          "order": [
            "x1",
            "y1",
            "x2",
            "y2"
          ]
        }
      ]
    }
  }
