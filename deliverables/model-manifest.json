  "output_format": {
    "raw_output_name": "output0",
    "raw_output_shape": [
      1,
      84,
      8400
    ],
    "raw_layout": "[batch, channels, candidates]",
    "decode": {
      "transpose_to": [
        8400,
        84
      ],
      "candidate_vector_layout": [
        {
          "index_range": [
            0,
            3
