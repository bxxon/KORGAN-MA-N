        {
          "index_range": [
            4,
            83
          ],
          "name": "class_scores",
          "description": "80 per-class confidence scores aligned 1:1 with labels.txt."
        }
      ],
      "class_id_rule": "argmax(class_scores)",
      "confidence_rule": "max(class_scores)",
